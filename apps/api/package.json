{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env index.ts",
    "build": "tsup && cp ../../packages/store/generated/prisma/*.node ./api/ 2>/dev/null || true",
    "vercel-build": "cd ../.. && bun install && bun x turbo run build --filter=api"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.9.0",
    "better-auth": "^1.4.17",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "zod": "^3.25.67",
    "typescript": "^5.0.0",
    "store": "*"
  }
}