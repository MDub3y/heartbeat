{
  "version": 2,
  "functions": {
    "apps/api/index.ts": {
      "includeFiles": "packages/store/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "apps/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "apps/web/$1"
    }
  ]
}